.DS_Store
Thumbs.db

# Node / Tooling
node_modules/
npm-debug.log*

# Vercel
.vercel

# Editor
.idea/
.vscode/
*.log

# Interne Claude-/Memory-Konfigs
.claude/

# Asset-Sammlungen, die nicht von index.html referenziert werden
Vereinsbadekappen/
Badekappen Produktbilder/

# Alte Konzept-/Demo-Dateien (Backup, nicht zu deployen)
index-konzept-teal.html
formular-demo.html

# Openart-Originale (umbenannte Kopien wie hero-swimmer.jpg liegen daneben)
Bilder/openart-*
Bilder/Screenshot*
Bilder/MSC_IMG_*

# Logo-Quellordner (Illustrator + JPGs) – nur Bilder/logo-*.svg werden ausgeliefert
Logo/

# Original-JPGs/PNGs lokal behalten, aber nicht ins Repo (WebPs werden ausgeliefert)
Bilder/*.jpg
Bilder/*.jpeg
Bilder/*.png
Bilder/grid/*.jpg
Bilder/grid/*.jpeg
Bilder/grid/*.png

# Ausnahme: Social-/OG-Vorschaubild wird ausgeliefert (von index.html referenziert)
!Bilder/og-image.jpg
